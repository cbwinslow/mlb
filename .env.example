# Example .env file for the baseball Python application layer
#
# Copy this to `.env` at the repository root and adjust values as needed.
# uv / python-dotenv can load it for local development, while production
# and CI environments should prefer real environment variables.
#
# Environment selection
APP_ENV=local
LOG_LEVEL=INFO

# Core PostgreSQL connection
# Replace these with your local or remote Postgres settings.
DATABASE_URL=postgresql+asyncpg://mlb:mlb@localhost:5432/mlb
# Optional: override search_path; if omitted, database defaults apply.
DB_SCHEMA_SEARCH_PATH=meta,ref,raw_retrosheet,raw_chadwick,raw_lahman,raw_statcast,raw_mlbapi,raw_fangraphs,raw_bref,raw_espn,raw_odds,stg,core,mart,ml,ops,auth,api,util

# Workspace and operations defaults
DEFAULT_WORKSPACE_CODE=local-dev
DEFAULT_QUEUE_NAME=default

# Test and production examples (uncomment and adapt in your deployment tooling)
#
# APP_ENV=test
# DATABASE_URL=postgresql+asyncpg://mlb_test:mlb_test@localhost:5433/mlb_test
#
# APP_ENV=production
# DATABASE_URL=postgresql+asyncpg://mlb_prod:***@prod-db-host:5432/mlb_prod
